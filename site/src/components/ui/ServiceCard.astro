---
interface Props {
  title: string
  tagline: string
  description: string
  href: string
  class?: string
}

const { title, tagline, description, href, class: className } = Astro.props
---

<a
  href={href}
  class={`block bg-cream-200 hover:bg-white rounded-xl p-6 lg:p-8 shadow-sm hover:shadow-md border border-cream-300 transition-all duration-200 group ${className ?? ''}`}
>
  <h3 class="font-heading font-semibold text-xl text-charcoal-900 mb-1 group-hover:text-sage-500 transition-colors">{title}</h3>
  <p class="text-sm text-sage-500 italic mb-3">{tagline}</p>
  <p class="text-charcoal-700 text-sm leading-relaxed">{description}</p>
  <span class="inline-block mt-4 text-sm font-semibold text-sage-500 group-hover:underline">Learn more →</span>
</a>
