---
interface Props {
  href?: string
  variant?: 'primary' | 'secondary' | 'ghost'
  size?: 'sm' | 'md' | 'lg'
  type?: 'button' | 'submit'
  class?: string
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className,
} = Astro.props

const sizeClass = {
  sm: 'px-5 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-base',
}[size]

const variantClass = {
  primary:   'bg-sage-400 hover:bg-sage-500 text-white',
  secondary: 'bg-terra-400 hover:bg-terra-500 text-white',
  ghost:     'border-2 border-sage-400 text-sage-500 hover:bg-sage-50',
}[variant]

const baseClass = `inline-flex items-center justify-center font-semibold rounded-lg transition-colors duration-200 ${sizeClass} ${variantClass} ${className ?? ''}`
---

{href
  ? <a href={href} class={baseClass}><slot /></a>
  : <button type={type} class={baseClass}><slot /></button>
}
