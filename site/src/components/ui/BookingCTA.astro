---
/**
 * CALENDLY BOOKING CTA
 * Uses Calendly popup widget. Calendly CSS/JS loaded in BaseLayout.astro.
 *
 * TO UPDATE WITH FERN'S REAL CALENDLY LINKS:
 * Replace the URLs in CALENDLY_URLS below with her actual event URLs.
 * Each eventType can point to a different Calendly event.
 */

interface Props {
  eventType?: 'discovery' | 'paid-30' | 'paid-60'
  label?: string
  variant?: 'primary' | 'secondary'
  size?: 'md' | 'lg'
  class?: string
}

const {
  eventType = 'discovery',
  label = 'Book a Free 30-Minute Discovery Call',
  variant = 'primary',
  size = 'lg',
  class: className,
} = Astro.props

const CALENDLY_URLS: Record<string, string> = {
  discovery:  'https://calendly.com/jgsookhoo/life-coaching-session',
  'paid-30':  'https://calendly.com/jgsookhoo/life-coaching-session',
  'paid-60':  'https://calendly.com/jgsookhoo/life-coaching-session',
}

const calendlyUrl = CALENDLY_URLS[eventType]

const sizeClass = size === 'lg' ? 'px-8 py-4 text-base' : 'px-6 py-3 text-sm'

const variantClass = variant === 'primary'
  ? 'bg-sage-400 hover:bg-sage-500 text-white'
  : 'bg-terra-400 hover:bg-terra-500 text-white'

const classes = `inline-flex items-center justify-center font-semibold rounded-lg transition-colors duration-200 cursor-pointer ${sizeClass} ${variantClass} ${className ?? ''}`
---

<a
  href={calendlyUrl}
  onclick={`Calendly.initPopupWidget({url: '${calendlyUrl}'}); return false;`}
  class={classes}
>
  {label}
</a>
