---
interface Props {
  quote: string
  name: string
  location?: string
  result?: string
  class?: string
}

const { quote, name, location, result, class: className } = Astro.props
---

<blockquote class={`bg-white rounded-xl p-6 lg:p-8 shadow-sm border border-cream-200 flex flex-col ${className ?? ''}`}>
  {result && (
    <p class="font-semibold text-sage-500 mb-3 text-sm">{result}</p>
  )}
  <p class="italic text-charcoal-700 leading-relaxed flex-1">"{quote}"</p>
  <footer class="mt-4 pt-4 border-t border-cream-200 text-sm text-charcoal-500">
    — {name}{location ? `, ${location}` : ''}
  </footer>
</blockquote>
