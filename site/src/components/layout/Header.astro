---
import { SITE } from '../../data/site'
import { NAV_SERVICES, NAV_HELP } from '../../data/navigation'
const path = Astro.url.pathname
---

<header class="sticky top-0 z-50 bg-cream-100/95 backdrop-blur-sm border-b border-charcoal-200">
  <div class="container-content">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="Good Vibrations Health – Home">
        <span class="font-heading font-bold text-lg lg:text-xl text-sage-500 group-hover:text-sage-600 leading-tight">
          Good Vibrations Health
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1 xl:gap-2" aria-label="Main navigation">

        <a href="/" aria-current={path === '/' ? 'page' : undefined} class="px-3 py-2 text-sm font-medium text-charcoal-700 hover:text-sage-500 aria-[current=page]:text-sage-500 rounded-md hover:bg-sage-50 transition-colors">Home</a>
        <a href="/about/" aria-current={path.startsWith('/about') ? 'page' : undefined} class="px-3 py-2 text-sm font-medium text-charcoal-700 hover:text-sage-500 aria-[current=page]:text-sage-500 rounded-md hover:bg-sage-50 transition-colors">About</a>

        <!-- Services dropdown -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-charcoal-700 hover:text-sage-500 rounded-md hover:bg-sage-50 transition-colors" aria-haspopup="true">
            Services
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute left-0 top-full pt-1 w-64 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-150 z-50">
            <div class="bg-white rounded-xl shadow-lg border border-charcoal-200 py-3">
              <a href="/services/" class="block px-4 py-2 text-sm font-semibold text-sage-500 hover:bg-sage-50 transition-colors">All Services →</a>
              <hr class="my-2 border-charcoal-200" />
              {NAV_SERVICES.map(group => (
                <div class="mb-3">
                  <div class="px-4 py-1 text-xs font-semibold text-charcoal-500 uppercase tracking-wider">{group.group}</div>
                  {group.items.map(item => (
                    <a href={item.href} class="block px-4 py-1.5 text-sm text-charcoal-700 hover:text-sage-500 hover:bg-sage-50 transition-colors">{item.label}</a>
                  ))}
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Help dropdown -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-charcoal-700 hover:text-sage-500 rounded-md hover:bg-sage-50 transition-colors" aria-haspopup="true">
            I Need Help With…
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute left-0 top-full pt-1 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-150 z-50">
            <div class="bg-white rounded-xl shadow-lg border border-charcoal-200 py-3">
              {NAV_HELP.map(item => (
                <a href={item.href} class="block px-4 py-2 text-sm text-charcoal-700 hover:text-sage-500 hover:bg-sage-50 transition-colors">{item.label}</a>
              ))}
            </div>
          </div>
        </div>

        <a href="/testimonials/" class="px-3 py-2 text-sm font-medium text-charcoal-700 hover:text-sage-500 rounded-md hover:bg-sage-50 transition-colors">Testimonials</a>
        <a href="/blog/" class="px-3 py-2 text-sm font-medium text-charcoal-700 hover:text-sage-500 rounded-md hover:bg-sage-50 transition-colors">Blog</a>
      </nav>

      <!-- Right side: phone (desktop) + Book Now + hamburger -->
      <div class="flex items-center gap-3">
        <a
          href={`tel:${SITE.phone.replace(/[^0-9]/g, '')}`}
          class="hidden lg:flex items-center gap-1.5 text-sm text-charcoal-600 hover:text-sage-500 transition-colors"
          aria-label={`Call Fern at ${SITE.phone}`}
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>{SITE.phone}</span>
        </a>

        <a
          href="/book/"
          onclick={`Calendly.initPopupWidget({url: 'https://calendly.com/jgsookhoo/life-coaching-session'}); return false;`}
          class="hidden sm:inline-flex items-center bg-terra-400 hover:bg-terra-500 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors duration-200"
        >
          Book Now
        </a>

        <!-- Hamburger (mobile only) -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-md text-charcoal-700 hover:bg-sage-100 transition-colors"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!--
  Mobile full-screen overlay.
  Lives as a sibling of <header> (not a child) so that fixed positioning
  is correctly anchored to the viewport with no stacking-context conflicts.
-->
<div
  id="mobile-menu"
  class="hidden fixed inset-0 z-[200] bg-cream-100 flex flex-col lg:hidden"
  aria-label="Mobile navigation"
  role="dialog"
  aria-modal="true"
>
  <!-- Overlay header bar: logo + close button -->
  <div class="flex items-center justify-between px-6 h-16 border-b border-charcoal-200 shrink-0">
    <a href="/" class="font-heading font-bold text-lg text-sage-500">
      Good Vibrations Health
    </a>
    <button
      id="mobile-menu-close"
      class="p-2 rounded-md text-charcoal-700 hover:bg-sage-100 transition-colors"
      aria-label="Close navigation menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Scrollable nav links -->
  <nav class="flex-1 overflow-y-auto px-4 py-4 space-y-1">
    {[
      { label: 'Home',               href: '/' },
      { label: 'About',              href: '/about/' },
      { label: 'Services',           href: '/services/' },
      { label: 'I Need Help With…',  href: '/help/' },
      { label: 'Testimonials',       href: '/testimonials/' },
      { label: 'Blog',               href: '/blog/' },
    ].map(item => (
      <a
        href={item.href}
        aria-current={path === item.href ? 'page' : undefined}
        class="flex items-center px-4 py-3.5 text-lg font-medium text-charcoal-700 hover:text-sage-500 aria-[current=page]:text-sage-500 rounded-xl hover:bg-sage-50 transition-colors"
      >
        {item.label}
      </a>
    ))}
  </nav>

  <!-- Pinned bottom actions -->
  <div class="shrink-0 px-4 pb-8 pt-4 border-t border-charcoal-200 space-y-3">
    <a
      href={`tel:${SITE.phone.replace(/[^0-9]/g, '')}`}
      class="flex items-center justify-center gap-2 w-full py-3 text-base font-medium text-charcoal-700 hover:text-sage-500 rounded-xl hover:bg-sage-50 transition-colors border border-charcoal-200"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      {SITE.phone}
    </a>
    <a
      href="/book/"
      onclick={`Calendly.initPopupWidget({url: 'https://calendly.com/jgsookhoo/life-coaching-session'}); return false;`}
      class="block w-full text-center bg-terra-400 hover:bg-terra-500 text-white font-semibold px-4 py-4 rounded-xl transition-colors text-base"
    >
      Book Now
    </a>
  </div>
</div>

<script>
  const openBtn  = document.getElementById('mobile-menu-btn')
  const closeBtn = document.getElementById('mobile-menu-close')
  const menu     = document.getElementById('mobile-menu')

  function setMenuOpen(open: boolean) {
    menu?.classList.toggle('hidden', !open)
    openBtn?.setAttribute('aria-expanded', String(open))
    // Prevent page scroll while overlay is visible
    document.body.style.overflow = open ? 'hidden' : ''
  }

  openBtn?.addEventListener('click',  () => setMenuOpen(true))
  closeBtn?.addEventListener('click', () => setMenuOpen(false))

  // Close on desktop resize
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) setMenuOpen(false)
  })

  // Close when any nav link is tapped
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => setMenuOpen(false))
  })
</script>
