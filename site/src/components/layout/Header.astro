---
import { SITE } from '../../data/site'
import { NAV_SERVICES, NAV_HELP } from '../../data/navigation'
const path = Astro.url.pathname
---

<header class="sticky top-0 z-50 bg-cream-100/95 backdrop-blur-sm border-b border-charcoal-200">
  <div class="container-content">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="Good Vibrations Health – Home">
        <span class="font-heading font-bold text-lg lg:text-xl text-sage-500 group-hover:text-sage-600 leading-tight">
          Good Vibrations<br class="hidden sm:block" /><span class="hidden sm:inline"> Health</span><span class="sm:hidden"> Health</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1 xl:gap-2" aria-label="Main navigation">

        <a href="/" aria-current={path === '/' ? 'page' : undefined} class="px-3 py-2 text-sm font-medium text-charcoal-700 hover:text-sage-500 aria-[current=page]:text-sage-500 rounded-md hover:bg-sage-50 transition-colors">Home</a>
        <a href="/about/" aria-current={path.startsWith('/about') ? 'page' : undefined} class="px-3 py-2 text-sm font-medium text-charcoal-700 hover:text-sage-500 aria-[current=page]:text-sage-500 rounded-md hover:bg-sage-50 transition-colors">About</a>

        <!-- Services dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-charcoal-700 hover:text-sage-500 rounded-md hover:bg-sage-50 transition-colors"
            aria-haspopup="true"
          >
            Services
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute left-0 top-full pt-1 w-64 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-150 z-50">
            <div class="bg-white rounded-xl shadow-lg border border-charcoal-200 py-3">
              <a href="/services/" class="block px-4 py-2 text-sm font-semibold text-sage-500 hover:bg-sage-50 transition-colors">
                All Services →
              </a>
              <hr class="my-2 border-charcoal-200" />
              {NAV_SERVICES.map(group => (
                <div class="mb-3">
                  <div class="px-4 py-1 text-xs font-semibold text-charcoal-500 uppercase tracking-wider">{group.group}</div>
                  {group.items.map(item => (
                    <a href={item.href} class="block px-4 py-1.5 text-sm text-charcoal-700 hover:text-sage-500 hover:bg-sage-50 transition-colors">
                      {item.label}
                    </a>
                  ))}
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Help dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-charcoal-700 hover:text-sage-500 rounded-md hover:bg-sage-50 transition-colors"
            aria-haspopup="true"
          >
            I Need Help With…
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute left-0 top-full pt-1 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-150 z-50">
            <div class="bg-white rounded-xl shadow-lg border border-charcoal-200 py-3">
              {NAV_HELP.map(item => (
                <a href={item.href} class="block px-4 py-2 text-sm text-charcoal-700 hover:text-sage-500 hover:bg-sage-50 transition-colors">
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        <a href="/testimonials/" class="px-3 py-2 text-sm font-medium text-charcoal-700 hover:text-sage-500 rounded-md hover:bg-sage-50 transition-colors">Testimonials</a>
        <a href="/blog/" class="px-3 py-2 text-sm font-medium text-charcoal-700 hover:text-sage-500 rounded-md hover:bg-sage-50 transition-colors">Blog</a>
      </nav>

      <!-- Phone + Book Now button (always visible) + mobile hamburger -->
      <div class="flex items-center gap-3">
        <a
          href={`tel:${SITE.phone.replace(/[^0-9]/g, '')}`}
          class="hidden lg:flex items-center gap-1.5 text-sm text-charcoal-600 hover:text-sage-500 transition-colors"
          aria-label={`Call Fern at ${SITE.phone}`}
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>{SITE.phone}</span>
        </a>
        <a
          href="/book/"
          onclick={`Calendly.initPopupWidget({url: 'https://calendly.com/jgsookhoo/life-coaching-session'}); return false;`}
          class="hidden sm:inline-flex items-center bg-terra-400 hover:bg-terra-500 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors duration-200"
        >
          Book Now
        </a>

        <!-- Hamburger (mobile) -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-md text-charcoal-700 hover:bg-sage-100 transition-colors"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
        >
          <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu — compact, scrollable, locks body scroll when open -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden fixed inset-x-0 top-[4rem] bottom-0 z-40 bg-cream-100 overflow-y-auto border-t border-charcoal-200"
  >
    <nav class="container-content py-5 space-y-1" aria-label="Mobile navigation">

      <!-- Primary links -->
      {[
        { label: 'Home',            href: '/' },
        { label: 'About',           href: '/about/' },
        { label: 'Services',        href: '/services/' },
        { label: 'I Need Help With…', href: '/help/' },
        { label: 'Testimonials',    href: '/testimonials/' },
        { label: 'Blog',            href: '/blog/' },
      ].map(item => (
        <a
          href={item.href}
          aria-current={path === item.href ? 'page' : undefined}
          class="block px-3 py-3 text-base font-medium text-charcoal-700 hover:text-sage-500 aria-[current=page]:text-sage-500 rounded-md hover:bg-sage-50 transition-colors"
        >
          {item.label}
        </a>
      ))}

      <!-- Divider -->
      <div class="pt-3 pb-1 border-t border-charcoal-200">
        <!-- Phone -->
        <a
          href={`tel:${SITE.phone.replace(/[^0-9]/g, '')}`}
          class="flex items-center gap-3 px-3 py-3 text-base font-medium text-charcoal-700 hover:text-sage-500 rounded-md hover:bg-sage-50 transition-colors"
        >
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {SITE.phone}
        </a>

        <!-- Book Now -->
        <div class="mt-3 px-1">
          <a
            href="/book/"
            onclick={`Calendly.initPopupWidget({url: 'https://calendly.com/jgsookhoo/life-coaching-session'}); return false;`}
            class="block w-full text-center bg-terra-400 hover:bg-terra-500 text-white font-semibold px-4 py-3 rounded-lg transition-colors"
          >
            Book Now
          </a>
        </div>
      </div>

    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  const iconOpen = document.getElementById('icon-open')
  const iconClose = document.getElementById('icon-close')

  function setMenuOpen(open: boolean) {
    menu?.classList.toggle('hidden', !open)
    iconOpen?.classList.toggle('hidden', open)
    iconClose?.classList.toggle('hidden', !open)
    btn?.setAttribute('aria-expanded', String(open))
    // Lock/unlock body scroll
    document.body.style.overflow = open ? 'hidden' : ''
    // Keep the menu top aligned to the header bottom
    if (menu) {
      const header = document.querySelector('header')
      menu.style.top = header ? `${header.offsetHeight}px` : '4rem'
    }
  }

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden')
    setMenuOpen(!isOpen)
  })

  // Close on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024 && !menu?.classList.contains('hidden')) {
      setMenuOpen(false)
    }
  })

  // Close when a nav link is tapped (so page navigates cleanly)
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => setMenuOpen(false))
  })
</script>
