---
import { SITE } from '../../data/site'
import { ALL_SERVICES } from '../../data/navigation'
---

<footer class="bg-sage-900 text-sage-100">
  <!-- Main footer -->
  <div class="container-content py-14 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-16">

      <!-- Col 1: Brand + contact -->
      <div>
        <p class="font-heading font-bold text-lg text-white mb-2">{SITE.name}</p>
        <p class="text-sage-300 text-sm mb-5 italic">{SITE.tagline}</p>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={`tel:${SITE.phone.replace(/-/g, '')}`} class="text-sage-200 hover:text-white transition-colors">
              {SITE.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${SITE.email}`} class="text-sage-200 hover:text-white transition-colors">
              {SITE.email}
            </a>
          </li>
          <li class="text-sage-300">{SITE.location}</li>
          <li class="text-sage-300">{SITE.serviceArea}</li>
        </ul>
        <div class="flex gap-4 mt-5">
          <a href={SITE.social.facebook} class="text-sage-300 hover:text-white transition-colors text-sm" target="_blank" rel="noopener noreferrer">
            Facebook
          </a>
          <a href={SITE.social.twitter} class="text-sage-300 hover:text-white transition-colors text-sm" target="_blank" rel="noopener noreferrer">
            X / Twitter
          </a>
        </div>
      </div>

      <!-- Col 2: Quick links -->
      <div>
        <p class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Quick Links</p>
        <ul class="space-y-2">
          {[
            { label: 'Home',         href: '/' },
            { label: 'About Fern',   href: '/about/' },
            { label: 'All Services', href: '/services/' },
            { label: 'I Need Help With…', href: '/help/' },
            { label: 'Testimonials', href: '/testimonials/' },
            { label: 'FAQ',          href: '/faq/' },
            { label: 'Blog',         href: '/blog/' },
            { label: 'Training & Speaking', href: '/training/' },
            { label: 'Book a Session', href: '/book/' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-sage-200 hover:text-white text-sm transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Services -->
      <div>
        <p class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Services</p>
        <ul class="space-y-2">
          {ALL_SERVICES.map(service => (
            <li>
              <a href={service.href} class="text-sage-200 hover:text-white text-sm transition-colors">{service.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Disclaimer strip -->
  <div class="border-t border-sage-800">
    <div class="container-content py-6">
      <p class="text-sage-400 text-xs leading-relaxed mb-3">
        Services are not a substitute for professional medical, psychological, or counselling care. Individual results vary and are not guaranteed.
      </p>
      <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-sage-400">
        <span>© {new Date().getFullYear()} {SITE.name}</span>
        <a href="/privacy-policy/" class="hover:text-sage-200 transition-colors">Privacy Policy</a>
        <a href="/terms/" class="hover:text-sage-200 transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
