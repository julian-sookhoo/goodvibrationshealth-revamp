---
import BookingCTA from '../ui/BookingCTA.astro'

interface Props {
  heading?: string
  body?: string
  label?: string
  eventType?: 'discovery' | 'paid-30' | 'paid-60'
}

const {
  heading = 'Ready to feel the difference?',
  body = 'Your first session includes a complimentary extra 15 minutes. And if cost is a concern, let\'s talk — nobody is turned away.',
  label = 'Book Your Free 30-Minute Discovery Call',
  eventType = 'discovery',
} = Astro.props
---

<section class="bg-sage-500 section-pad">
  <div class="container-content text-center">
    <h2 class="font-heading font-bold text-3xl lg:text-4xl text-white mb-4">{heading}</h2>
    <p class="text-sage-100 text-lg mb-8 max-w-xl mx-auto leading-relaxed">{body}</p>
    <BookingCTA {label} {eventType} variant="secondary" />
  </div>
</section>
