---
import BookingCTA from '../ui/BookingCTA.astro'
import Button from '../ui/Button.astro'
import CredibilityBar from '../ui/CredibilityBar.astro'
import PlaceholderImage from '../ui/PlaceholderImage.astro'
---

<section class="bg-cream-100 py-16 lg:py-24">
  <div class="container-content">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Text -->
      <div>
        <h1 class="font-heading font-bold text-4xl sm:text-5xl lg:text-6xl text-charcoal-900 leading-tight mb-6">
          Feel Better.<br />
          Think Clearer.<br />
          <span class="text-sage-500">Live With Less Pain.</span>
        </h1>
        <p class="text-lg lg:text-xl text-charcoal-700 mb-6 leading-relaxed">
          Natural therapies that work — even when nothing else has. Virtual sessions available worldwide.
        </p>
        <CredibilityBar />
        <div class="flex flex-wrap gap-4 mt-6 justify-center sm:justify-start">
          <BookingCTA label="Book a Free Discovery Call" variant="primary" />
          <Button href="/services/" variant="ghost" size="lg">Explore Services</Button>
        </div>
      </div>

      <!-- Photo -->
      <div class="relative">
        <PlaceholderImage width={800} height={900} alt="Fern Wolf, holistic health practitioner" class="max-w-sm mx-auto lg:max-w-none" />
      </div>
    </div>
  </div>
</section>
