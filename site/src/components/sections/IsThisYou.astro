---
import Button from '../ui/Button.astro'

const problems = [
  'Chronic pain that doctors can\'t fully explain or resolve',
  'Anxiety or stress that affects your sleep, work, or relationships',
  'Fears or phobias holding you back from the life you want',
  'Habits you\'ve tried — and failed — to change on your own',
  'Grief, trauma, or emotional pain you haven\'t been able to move past',
  'A sense that you\'re meant for more, but you don\'t know where to start',
]
---

<section class="bg-cream-200 section-pad">
  <div class="container-content">
    <div class="max-w-narrow mx-auto text-center">
      <h2 class="font-heading font-semibold text-3xl lg:text-4xl text-charcoal-900 mb-4">
        You don't have to keep living this way.
      </h2>
      <p class="text-lg text-charcoal-700 mb-10">If any of these feel familiar, you're in the right place:</p>
    </div>

    <ul class="max-w-2xl mx-auto space-y-4 mb-12">
      {problems.map(problem => (
        <li class="flex items-start gap-3">
          <span class="mt-1 w-5 h-5 shrink-0 rounded-full bg-sage-200 flex items-center justify-center">
            <svg class="w-3 h-3 text-sage-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
          </span>
          <span class="text-charcoal-700 text-base leading-relaxed">{problem}</span>
        </li>
      ))}
    </ul>

    <div class="text-center">
      <Button href="/help/" variant="secondary" size="lg">Find out how I can help →</Button>
    </div>
  </div>
</section>
