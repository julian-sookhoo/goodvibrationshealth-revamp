---
import BaseLayout from '../components/layout/BaseLayout.astro'
import { SITE } from '../data/site'
---

<BaseLayout
  title="Training & Speaking — Good Vibrations Health"
  description="TFT Certificate Algorithm Course, free monthly TFT intro sessions, and speaking engagements with Fern Wolf. Virtual training available across Canada."
>
  <!-- Hero -->
  <section class="bg-cream-200 py-14 lg:py-20">
    <div class="container-content max-w-narrow">
      <h1 class="font-heading font-bold text-4xl lg:text-5xl text-charcoal-900 mb-4">
        Learn the tools. Teach them to others.
      </h1>
      <p class="text-lg text-charcoal-700 leading-relaxed">
        I believe the most powerful healing work is the kind you can take home with you. Beyond 1:1 sessions, I offer public training in Thought Field Therapy — so that you can use these techniques yourself, share them with others, and carry them into your practice if you're a fellow professional.
      </p>
    </div>
  </section>

  <!-- TFT Training -->
  <section class="bg-cream-100 py-14 lg:py-20">
    <div class="container-content max-w-narrow">
      <h2 class="font-heading font-semibold text-3xl text-charcoal-900 mb-10">TFT Training Courses</h2>

      <!-- Certificate Course -->
      <div class="bg-cream-200 rounded-xl p-8 border border-cream-300 mb-8">
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="bg-sage-400 text-white text-xs font-semibold px-3 py-1 rounded-full">Paid Course</span>
          <span class="bg-cream-100 text-charcoal-600 text-xs font-semibold px-3 py-1 rounded-full border border-cream-300">Online via Zoom</span>
        </div>
        <h3 class="font-heading font-semibold text-2xl text-charcoal-900 mb-2">TFT Certificate Algorithm Course</h3>
        <p class="text-charcoal-700 mb-6">Learn the full set of TFT tapping algorithms at the certificate level. Upon completion, you'll receive a TFT tapping algorithm certificate.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
          {[
            { label: 'Format', value: 'Online via Zoom' },
            { label: 'Duration', value: '~6 hours (10:30am–4:30pm)' },
            { label: 'Cost', value: '$180 CAD' },
            { label: 'Certificate', value: 'Included upon completion' },
          ].map(item => (
            <div>
              <p class="text-xs font-semibold text-charcoal-500 uppercase tracking-wider">{item.label}</p>
              <p class="text-charcoal-900 font-medium">{item.value}</p>
            </div>
          ))}
        </div>
        <p class="text-charcoal-600 text-sm mb-5 italic">Who it's for: Practitioners, coaches, therapists, and individuals who want to use TFT professionally or for personal development.</p>
        <a
          href={`mailto:${SITE.email}?subject=${encodeURIComponent('TFT Certificate Algorithm Course — Registration')}`}
          class="inline-flex items-center bg-sage-400 hover:bg-sage-500 text-white font-semibold px-6 py-3 rounded-lg transition-colors duration-200"
        >
          Register via Email →
        </a>
      </div>

      <!-- Free Monthly Intro -->
      <div class="bg-cream-200 rounded-xl p-8 border border-cream-300">
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="bg-terra-400 text-white text-xs font-semibold px-3 py-1 rounded-full">Free (donations optional)</span>
          <span class="bg-cream-100 text-charcoal-600 text-xs font-semibold px-3 py-1 rounded-full border border-cream-300">Monthly</span>
        </div>
        <h3 class="font-heading font-semibold text-2xl text-charcoal-900 mb-2">Free Monthly Introduction to TFT Tapping</h3>
        <p class="text-charcoal-700 mb-6">A one-hour introduction to Thought Field Therapy — completely free, held every month. This is the lowest-risk way to experience TFT firsthand and decide if you'd like to explore further.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
          {[
            { label: 'Format', value: 'Online via Zoom' },
            { label: 'Frequency', value: 'First Tuesday of every month' },
            { label: 'Time', value: '12:30–1:30pm EST' },
            { label: 'Cost', value: 'Free (donations optional)' },
          ].map(item => (
            <div>
              <p class="text-xs font-semibold text-charcoal-500 uppercase tracking-wider">{item.label}</p>
              <p class="text-charcoal-900 font-medium">{item.value}</p>
            </div>
          ))}
        </div>
        <a
          href={`mailto:${SITE.email}?subject=${encodeURIComponent('Free Monthly TFT Intro — Registration')}`}
          class="inline-flex items-center bg-terra-400 hover:bg-terra-500 text-white font-semibold px-6 py-3 rounded-lg transition-colors duration-200"
        >
          Register for Next Session →
        </a>
      </div>
    </div>
  </section>

  <!-- Speaking -->
  <section class="bg-cream-200 py-14 lg:py-20">
    <div class="container-content max-w-narrow">
      <h2 class="font-heading font-semibold text-3xl text-charcoal-900 mb-4">Bring Fern to your event</h2>
      <p class="text-charcoal-700 mb-8 leading-relaxed">
        I'm available as a guest speaker for wellness events, corporate health days, retreat programs, conferences, and podcast appearances. Topics are customized to your audience and event theme.
      </p>

      <div class="bg-cream-100 rounded-xl p-6 mb-8">
        <h3 class="font-heading font-semibold text-lg text-charcoal-900 mb-4">Speaking topics include:</h3>
        <ul class="space-y-2">
          {[
            'The science and practice of Thought Field Therapy',
            'Energy psychology and the mind-body connection',
            'Water, consciousness, and vibrational wellbeing (HADO)',
            'Hypnosis: myths, realities, and results',
            'Subconscious belief change: how our thoughts create our health',
            'Holistic approaches to anxiety, stress, and resilience',
            'Non-duality and natural wellbeing',
          ].map(topic => (
            <li class="flex items-start gap-2 text-charcoal-700 text-sm">
              <span class="text-sage-400 mt-1">→</span>
              {topic}
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-heading font-semibold text-lg text-charcoal-900 mb-3">Book a speaking engagement</h3>
        <p class="text-charcoal-700 text-sm mb-4">Please include your event name, audience size, format (virtual/in-person), date, and topic interest.</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={`mailto:${SITE.email}?subject=${encodeURIComponent('Speaking Enquiry')}`} class="text-sage-500 hover:underline font-medium">
            {SITE.email}
          </a>
          <span class="hidden sm:inline text-charcoal-300">·</span>
          <a href={`tel:${SITE.phone}`} class="text-sage-500 hover:underline font-medium">
            {SITE.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-cream-100 py-14 lg:py-20">
    <div class="container-content max-w-narrow text-center">
      <h2 class="font-heading font-semibold text-2xl text-charcoal-900 mb-4">Ready to learn?</h2>
      <p class="text-charcoal-700 mb-8">Whether you want to attend a training or book Fern for your event, the first step is a conversation.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={`mailto:${SITE.email}?subject=${encodeURIComponent('Training or Speaking Enquiry')}`}
          class="inline-flex items-center bg-sage-400 hover:bg-sage-500 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          Get in touch
        </a>
        <a
          href="/book/"
          class="inline-flex items-center border-2 border-sage-400 text-sage-500 hover:bg-sage-50 font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          Or book a 1:1 session
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
