---
import { getCollection } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import BaseLayout from '../../components/layout/BaseLayout.astro'
import CTABanner from '../../components/sections/CTABanner.astro'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }))
}

type Props = { entry: CollectionEntry<'blog'> }
const { entry } = Astro.props
const { Content } = await entry.render()
const { title, date, excerpt } = entry.data

const formattedDate = date.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<BaseLayout
  title={title}
  description={excerpt}
>
  <!-- Hero -->
  <section class="bg-cream-200 py-14 lg:py-20">
    <div class="container-content max-w-narrow">
      <p class="text-sm font-semibold text-sage-500 uppercase tracking-wider mb-3">
        <a href="/blog/" class="hover:underline">Blog</a>
      </p>
      <h1 class="font-heading font-bold text-4xl lg:text-5xl text-charcoal-900 leading-tight mb-4">
        {title}
      </h1>
      <time class="text-charcoal-500 text-sm">{formattedDate}</time>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-cream-100 py-12 lg:py-16">
    <div class="container-content max-w-narrow">
      <div class="prose-gv">
        <Content />
      </div>

    </div>
  </section>

  <CTABanner heading="Ready to experience this for yourself?" />
</BaseLayout>
