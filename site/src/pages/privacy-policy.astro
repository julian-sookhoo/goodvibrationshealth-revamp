---
import BaseLayout from '../components/layout/BaseLayout.astro'
import { SITE } from '../data/site'
---

<BaseLayout
  title="Privacy Policy — Good Vibrations Health"
  description="Privacy Policy for Good Vibrations Health. How we collect, use, and protect your personal information in accordance with PIPEDA."
  noindex={true}
>
  <section class="bg-cream-200 py-14 lg:py-20">
    <div class="container-content max-w-narrow">
      <h1 class="font-heading font-bold text-4xl text-charcoal-900 mb-3">Privacy Policy</h1>
      <p class="text-charcoal-500 text-sm">This page is being finalized. The legal text below will be replaced with a complete PIPEDA-compliant privacy policy before launch.</p>
    </div>
  </section>

  <section class="bg-cream-100 py-12 lg:py-16">
    <div class="container-content max-w-narrow">
      <div class="prose-gv">

        <h2>About This Policy</h2>
        <p>Good Vibrations Health is committed to protecting the privacy of our clients and website visitors. This policy describes what information we collect, how we use it, and your rights under Canada's <em>Personal Information Protection and Electronic Documents Act</em> (PIPEDA).</p>
        <p><strong>Note:</strong> This is a draft stub. The complete privacy policy — including specific third-party processors (booking platform, analytics, email tools) — will be published before this site goes live.</p>

        <h2>Information We Collect</h2>
        <ul>
          <li>Name, email, and phone number submitted via contact forms</li>
          <li>Session intake information collected via our booking platform</li>
          <li>IP address and browsing data collected via Google Analytics (GA4)</li>
          <li>Cookies used for analytics and functionality</li>
        </ul>

        <h2>How We Use It</h2>
        <ul>
          <li>To respond to enquiries and provide services</li>
          <li>To send appointment reminders and follow-up communications (with consent)</li>
          <li>To improve our website and understand how visitors use it</li>
        </ul>

        <h2>Sharing With Third Parties</h2>
        <p>We do not sell personal information. Data may be processed by third-party service providers (booking platform, analytics, email tools) under data processing agreements. A full list of processors will be published in the final policy.</p>

        <h2>Your Rights Under PIPEDA</h2>
        <p>You have the right to access, correct, and withdraw consent for the use of your personal information. To exercise these rights, contact us at the address below.</p>

        <h2>Contact for Privacy Questions</h2>
        <p>
          Fern Wolf<br />
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a><br />
          <a href={`tel:${SITE.phone}`}>{SITE.phone}</a>
        </p>

        <h2>Effective Date</h2>
        <p>This policy will be effective as of the site's official launch date.</p>

      </div>
    </div>
  </section>
</BaseLayout>
