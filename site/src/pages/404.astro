---
import BaseLayout from '../components/layout/BaseLayout.astro'
import BookingCTA from '../components/ui/BookingCTA.astro'
import Button from '../components/ui/Button.astro'
---

<BaseLayout
  title="Page Not Found — Good Vibrations Health"
  description="The page you were looking for doesn't exist. Find holistic health services, book a session, or explore what Fern Wolf can help you with."
  noindex={true}
>
  <section class="bg-cream-100 min-h-[70vh] flex items-center">
    <div class="container-content max-w-narrow text-center py-20">
      <p class="font-heading text-8xl font-bold text-sage-200 mb-4">404</p>
      <h1 class="font-heading font-bold text-3xl text-charcoal-900 mb-4">
        This page doesn't exist.
      </h1>
      <p class="text-lg text-charcoal-700 mb-10 max-w-md mx-auto">
        The link you followed may be outdated. If you were looking for a service or information about working with Fern, try one of these:
      </p>
      <div class="flex flex-wrap justify-center gap-4 mb-10">
        <Button href="/" variant="primary">Home</Button>
        <Button href="/services/" variant="ghost">All Services</Button>
        <Button href="/help/" variant="ghost">I Need Help With…</Button>
      </div>
      <BookingCTA label="Or Book a Free Discovery Call" />
    </div>
  </section>
</BaseLayout>
