---
import BaseLayout from '../components/layout/BaseLayout.astro'
import FAQAccordion from '../components/ui/FAQAccordion.astro'
import CTABanner from '../components/sections/CTABanner.astro'
import { SITE } from '../data/site'

const faqs = {
  'About the Services': [
    {
      q: 'Are these services safe?',
      a: 'Yes. Every modality I offer is non-invasive and drug-free. They are gentle enough to work alongside any existing medical treatment and carry no known harmful side effects.',
    },
    {
      q: 'How is this different from seeing a doctor or therapist?',
      a: 'Conventional medicine and therapy focus primarily on managing symptoms or working through issues consciously. My work targets the subconscious root of problems — the beliefs, emotional charges, and energy patterns that drive symptoms in the first place. For many clients, the two approaches complement each other beautifully.',
    },
    {
      q: 'Can I use these services alongside my current medical treatment?',
      a: "Absolutely. These services are not a replacement for medical care — they work alongside it. Always follow your doctor's advice for medical conditions. Many clients find that our work accelerates the results they're already pursuing.",
    },
    {
      q: 'How many sessions will I need?',
      a: "This varies by person and issue. Some clients experience complete resolution of a specific problem in a single session. Others benefit from a series of sessions for deeper, layered issues. I'll give you an honest assessment after your first appointment.",
    },
    {
      q: "What if I'm skeptical?",
      a: "Healthy skepticism is welcome here. You don't need to believe in a technique for it to work — you just need to be willing to try it. I'd invite you to book a free discovery call, tell me what you're dealing with, and let the results speak for themselves.",
    },
    {
      q: 'Which service is right for me?',
      a: 'Browse by condition at /help/ or by service category at /services/. If you\'re still unsure, a free 30-minute discovery call is the easiest way to find out — I\'ll ask a few questions and recommend the best starting point for your situation.',
    },
  ],
  'About Sessions': [
    {
      q: 'How do virtual sessions work?',
      a: "Sessions are conducted via video call (Zoom or a platform of your choice) or by phone. Most modalities I offer work effectively online. You'll need a quiet space where you can be comfortable and undisturbed for the length of your session.",
    },
    {
      q: 'What should I expect in my first appointment?',
      a: "We'll start by talking about what's brought you here — what you're experiencing, what you've already tried, and what you'd like to be different. From there, I'll recommend the best approach and we'll get to work. Many clients notice a meaningful shift in the first session.",
    },
    {
      q: 'Do you offer a free consultation?',
      a: 'Yes. Every new client is welcome to a free 30-minute discovery call. This is a chance to ask questions, share what you\'re dealing with, and get a feel for how I work — no commitment required.',
    },
  ],
  'Practical Questions': [
    {
      q: 'How much do sessions cost?',
      a: '30 minutes: $60 CAD · 60 minutes: $110 CAD. Your first session includes a complimentary extra 15 minutes.',
    },
    {
      q: 'Is this covered by insurance?',
      a: "Coverage varies by insurance plan and province. Some extended health plans cover services like hypnotherapy, life coaching, or NLP when provided by a certified practitioner. I recommend checking directly with your insurance provider. I'm happy to provide receipts for services rendered.",
    },
    {
      q: "What if I can't afford the full rate?",
      a: "Please don't let cost stop you from reaching out. I accept donations or exchanges of energy for clients who are genuinely experiencing financial hardship. Get in touch and we'll find something that works.",
    },
    {
      q: 'Do you offer packages or multi-session bundles?',
      a: 'Ask about ongoing coaching packages when you book a discovery call.',
    },
  ],
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: Object.values(faqs).flat().map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<BaseLayout
  title="FAQ — Good Vibrations Health"
  description="Common questions about non-duality coaching, TFT tapping, hypnosis & holistic sessions with Fern Wolf — pricing, what to expect, and how it works. Virtual sessions worldwide."
  schema={faqSchema}
>
  <!-- Hero -->
  <section class="bg-cream-200 py-14 lg:py-20">
    <div class="container-content max-w-narrow">
      <h1 class="font-heading font-bold text-4xl lg:text-5xl text-charcoal-900 mb-4">Questions? Good.</h1>
      <p class="text-lg text-charcoal-700">
        Trying something new — especially when it comes to your health — raises real questions. Here are the ones I hear most often. If yours isn't here, reach out directly: <a href={`mailto:${SITE.email}`} class="text-sage-500 hover:underline">{SITE.email}</a> or <a href={`tel:${SITE.phone}`} class="text-sage-500 hover:underline">{SITE.phone}</a>.
      </p>
    </div>
  </section>

  <!-- FAQ sections -->
  {Object.entries(faqs).map(([section, items], i) => (
    <section class={`${i % 2 === 0 ? 'bg-cream-100' : 'bg-cream-200'} py-12 lg:py-16`}>
      <div class="container-content max-w-narrow">
        <h2 class="font-heading font-semibold text-2xl text-charcoal-900 mb-8">{section}</h2>
        <FAQAccordion items={items} />
      </div>
    </section>
  ))}

  <!-- Still have questions -->
  <section class="bg-cream-200 py-14 lg:py-20">
    <div class="container-content max-w-narrow text-center">
      <h2 class="font-heading font-semibold text-2xl text-charcoal-900 mb-4">Still have questions?</h2>
      <p class="text-charcoal-700 mb-6">Reach out directly — I'm happy to help.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={`mailto:${SITE.email}`} class="text-sage-500 hover:underline font-medium">{SITE.email}</a>
        <span class="hidden sm:inline text-charcoal-300">·</span>
        <a href={`tel:${SITE.phone}`} class="text-sage-500 hover:underline font-medium">{SITE.phone}</a>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
